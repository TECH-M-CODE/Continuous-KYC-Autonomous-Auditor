# Application
PROJECT_NAME="CXKYC - Continuous KYC Autonomous Auditor"
API_V1_PREFIX="/api/v1"
ENVIRONMENT="development"
LOG_LEVEL="INFO"

# Security
JWT_SECRET_KEY="dev-secret-change-me"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="480"
RATE_LIMIT_PER_MINUTE="60"
# Comma-separated list of origins
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:5175"

# Database & Infrastructure
DATABASE_URL="sqlite+aiosqlite:///./data/sentinelai.db"
CHROMA_PERSIST_DIR="./data/chroma"
REDIS_URL="redis://localhost:6379"

# AI / LLM 
# Leave GOOGLE_API_KEY blank to automatically trigger the degradation ladder (Mock LLM)
GOOGLE_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
MASK_PII_BEFORE_LLM="True"
# LLM_MOCK_FAIL_RATE="1.0" # Uncomment to force 100% mock failure rate during rehearsals

# Telemetry
OTEL_EXPORTER_OTLP_ENDPOINT=""

# Datasets
DATA_DIR="./data"

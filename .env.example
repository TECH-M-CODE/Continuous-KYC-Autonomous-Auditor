# Copy this file to .env and adjust as needed. All values below are the
# actual defaults from app/config.py -- .env only needs to override what
# you're changing.

# App
ENVIRONMENT=development
LOG_LEVEL=INFO

# Security
JWT_SECRET_KEY=dev-secret-change-me
CORS_ORIGINS=http://localhost:5173

# Database & Infra
DATABASE_URL=sqlite+aiosqlite:///./data/sentinelai.db
CHROMA_PERSIST_DIR=./data/chroma
REDIS_URL=redis://localhost:6379

# AI / LLM -- leave GOOGLE_API_KEY blank to run entirely on the mock LLM
# ladder (no real Gemini calls, no billing, fully deterministic for demos).
# Set it to go live per Sprint 3's plan.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
MASK_PII_BEFORE_LLM=true

# Datasets
DATA_DIR=./data
